Cell[CellGroupData[{

Cell["6. Physical Implications", "Section",
 CellChangeTimes->{{3.9, 3.9}}],

Cell["\<\
Now let's discuss the physical meaning and experimental constraints on these \
operators.\
\>", "Text",
 CellChangeTimes->{{3.9, 3.9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{
   "Calculate", " ", "typical", " ", "constraints", " ", "on", " ", "Wilson",
     " ", "coefficients"}], " ", "*)"}], "\[IndentingNewLine]",
  RowBox[{
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{
     "\"\<\\n===== EXPERIMENTAL CONSTRAINTS =====\\n\>\""}], "]"}], ";"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"muonLifetimeUncertainty", "=",
     RowBox[{"22", "*",
      SuperscriptBox["10",
       RowBox[{"-", "13"}]]}]}], ";"}], "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"relativePrecision", "=",
     RowBox[{"muonLifetimeUncertainty", "/", "muonLifetime"}]}], ";"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{
     "\"\<1. MUON LIFETIME\>\"", ",", "\"\<\\n\>\"", ",",
      "\"\<   Measured: \[Tau]\[Mu] = \>\"", ",", "muonLifetime", ",",
      "\"\< \[PlusMinus] \>\"", ",", "muonLifetimeUncertainty", ",",
      "\"\< s\\n\>\"", ",", "\"\<   Precision: ~\>\"", ",",
      RowBox[{
       RowBox[{"NumberForm", "[",
        RowBox[{
         RowBox[{"relativePrecision", "*",
          SuperscriptBox["10", "6"]}], ",",
         RowBox[{"{",
          RowBox[{"3", ",", "1"}], "}"}]}], "]"}], "//", "ToString"}], ",",
      "\"\< ppm\\n\>\""}], "]"}], ";"}], "\[IndentingNewLine]",
   "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{
     "\"\<2. MICHEL PARAMETERS\>\"", ",", "\"\<\\n\>\"", ",",
      "\"\<   SM predictions: \[Rho] = 3/4, \[Delta] = 3/4\\n\>\"", ",",
      "\"\<   Measured: \[Rho] = 0.74979(26), \[Delta] = 0.75047(34)\\n\>\"",
      ",", "\"\<   Constrains scalar/tensor operators\\n\>\""}], "]"}],
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"constraintBound", "=",
     SuperscriptBox["10",
      RowBox[{"-", "6"}]]}], ";"}], "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"newPhysicsScale", "=",
     RowBox[{"Sqrt", "[",
      RowBox[{"vEW", "/",
       RowBox[{"Sqrt", "[", "constraintBound", "]"}]}], "]"}]}], ";"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{
     "\"\<3. WILSON COEFFICIENT CONSTRAINTS\>\"", ",", "\"\<\\n\>\"", ",",
      "\"\<   Typical bound: |C_i|/\[CapitalLambda]^2 \[LessSlantEqual] \>\"",
       ",", "constraintBound", ",", "\"\< GeV^-2\\n\>\"", ",",
      "\"\<   For O(1) coefficient: \[CapitalLambda] \[GreaterSlantEqual] \
\>\"", ",",
      RowBox[{"NumberForm", "[",
       RowBox[{"newPhysicsScale", ",", "3"}], "]"}], ",", "\"\< GeV\\n\>\""}],
      "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{
     "\"\<4. LEPTON FLAVOR VIOLATION\>\"", ",", "\"\<\\n\>\"", ",",
      "\"\<   BR(\[Mu] \[Rule] e\[Gamma]) < 4.2 \[Times] 10^-13\\n\>\"", ",",
       "\"\<   BR(\[Mu] \[Rule] 3e) < 1.0 \[Times] 10^-12\\n\>\"", ",",
      "\"\<   Constrains off-diagonal flavor operators\\n\>\""}], "]"}],
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{
     "\"\<5. LEPTON NUMBER VIOLATION\>\"", ",", "\"\<\\n\>\"", ",",
      "\"\<   No evidence for LNV in muon decay\\n\>\"", ",",
      "\"\<   Constrains C_i^LNV \[Times] (v/\[CapitalLambda])^2 < 10^-6\\n\>\
\"", ",",
      "\"\<   Correlated with neutrinoless double-beta decay\\n\>\""}], "]"}],
     ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9, 3.9}}]
}, Open  ]],

