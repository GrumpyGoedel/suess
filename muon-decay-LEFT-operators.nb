Notebook[{

Cell[CellGroupData[{
Cell["Muon Decay in LEFT: Complete Operator Analysis", "Title",
 CellChangeTimes->{{3.9, 3.9}}],

Cell["\<\
This notebook systematically derives and enumerates all dimension-6 LOW \
ENERGY EFFECTIVE FIELD THEORY (LEFT) operators relevant for muon decay using \
the Jenkins et al. operator basis (JHEP 1711, 059 (2017)).\
\>", "Text",
 CellChangeTimes->{{3.9, 3.9}}],

Cell[CellGroupData[{

Cell["1. Introduction and Setup", "Section",
 CellChangeTimes->{{3.9, 3.9}}],

Cell["\<\
LEFT is the effective field theory valid below the electroweak scale (~100 \
GeV), where the W, Z, and Higgs bosons have been integrated out. The \
relevant degrees of freedom are leptons, light quarks, gluons, and photons.

For muon decay, we focus on the purely leptonic sector with operators of the \
form:
    L_eff = L_SM + Sum_i (C_i/Lambda^2) O_i^(6)

where Lambda is the new physics scale and C_i are Wilson coefficients.\
\>", "Text",
 CellChangeTimes->{{3.9, 3.9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{"Basic", " ", "Setup"}], " ", "*)"}], "\[IndentingNewLine]",
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}],
   "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"SetDirectory", "[",
     RowBox[{"NotebookDirectory", "[", "]"}], "]"}], ";"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]",
   RowBox[{"(*", " ",
    RowBox[{"Physical", " ", "Constants"}], " ", "*)"}],
   "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"GFermi", "=",
     RowBox[{"1.1663787", "*",
      SuperscriptBox["10",
       RowBox[{"-", "5"}]]}]}], ";", " ",
    RowBox[{"(*", " ",
     RowBox[{"GeV", "^",
      RowBox[{"-", "2"}]}], " ", "*)"}], "\[IndentingNewLine]",
    RowBox[{"muonMass", "=", "0.1056583755"}], ";", " ",
    RowBox[{"(*", " ", "GeV", " ", "*)"}], "\[IndentingNewLine]",
    RowBox[{"muonLifetime", "=",
     RowBox[{"2.1969811", "*",
      SuperscriptBox["10",
       RowBox[{"-", "6"}]]}]}], ";", " ",
    RowBox[{"(*", " ", "seconds", " ", "*)"}], "\[IndentingNewLine]",
    RowBox[{"vEW", "=", "246.22"}], ";", " ",
    RowBox[{"(*", " ",
     RowBox[{"GeV", ",", " ",
      RowBox[{"EW", " ", "vev"}]}], " ", "*)"}], "\[IndentingNewLine]",
    "\[IndentingNewLine]",
    RowBox[{"Print", "[",
     RowBox[{
     "\"\<Physical Constants Loaded:\>\"", ",", "\"\<\\n\>\"", ",",
      "\"\<  G_F = \>\"", ",", "GFermi", ",", "\"\< GeV^-2\\n\>\"", ",",
      "\"\<  m_mu = \>\"", ",", "muonMass", ",", "\"\< GeV\\n\>\"", ",",
      "\"\<  tau_mu = \>\"", ",", "muonLifetime", ",", "\"\< s\\n\>\"", ",",
      "\"\<  v_EW = \>\"", ",", "vEW", ",", "\"\< GeV\>\""}], "]"}],
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9, 3.9}}],

Cell["\<\
We define the flavor basis for leptons and neutrinos that will appear in our \
operators.\
\>", "Text",
 CellChangeTimes->{{3.9, 3.9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{"Define", " ", "Flavor", " ", "Indices"}], " ", "*)"}],
  "\[IndentingNewLine]",
  RowBox[{
   RowBox[{
    RowBox[{"leptonFlavors", "=",
     RowBox[{"{",
      RowBox[{"\"\<e\>\"", ",", "\"\<\[Mu]\>\"", ",", "\"\<\[Tau]\>\""}],
      "}"}]}], ";"}], "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"neutrinos", "=",
     RowBox[{"{",
      RowBox[{
      "\"\<\[Nu]e\>\"", ",", "\"\<\[Nu]\[Mu]\>\"", ",",
       "\"\<\[Nu]\[Tau]\>\""}], "}"}]}], ";"}], "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"antiNeutrinos", "=",
     RowBox[{"{",
      RowBox[{
      "\"\<\!\(\*OverscriptBox[\(\[Nu]\), \(_\)]\)e\>\"", ",",
       "\"\<\!\(\*OverscriptBox[\(\[Nu]\), \(_\)]\)\[Mu]\>\"", ",",
       "\"\<\!\(\*OverscriptBox[\(\[Nu]\), \(_\)]\)\[Tau]\>\""}], "}"}]}],
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"chiralitiesCharged", "=",
     RowBox[{"{",
      RowBox[{"\"\<L\>\"", ",", "\"\<R\>\""}], "}"}]}], ";"}],
   "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"chiralitiesNeutrino", "=",
     RowBox[{"{", "\"\<L\>\"", "}"}]}], ";"}], "\[IndentingNewLine]",
   "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{"\"\<Flavor Basis:\>\""}], "]"}], ";"}],
   "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{"\"\<  Charged leptons: \>\"", ",", "leptonFlavors"}], "]"}],
    ";"}], "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{"\"\<  Neutrinos: \>\"", ",", "neutrinos"}], "]"}], ";"}],
   "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{"\"\<  Antineutrinos: \>\"", ",", "antiNeutrinos"}], "]"}],
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9, 3.9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell["2. Operator Structures in Jenkins Basis", "Section",
 CellChangeTimes->{{3.9, 3.9}}],

Cell["\<\
The Jenkins basis classifies four-fermion operators by their Lorentz \
structure and fermion chiralities. For muon decay (mu -> e + nu + nubar), we \
have:

Lepton-Number Conserving (Delta L = 0): (ebar Gamma mu)(nubar Gamma' nu)
Lepton-Number Violating (Delta L = 2): (ebar Gamma mu)(nubar^c Gamma' nubar)

The Lorentz structures are:
  V = Vector (gamma^mu)
  S = Scalar (identity)
  T = Tensor (sigma^{mu nu})

Combined with chirality (L/R), we get all possible operator structures.\
\>", "Text",
 CellChangeTimes->{{3.9, 3.9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{
   "Define", " ", "Lepton", " ", "Number", " ", "Conserving", " ",
    "Operators"}], " ", "*)"}], "\[IndentingNewLine]",
  RowBox[{
   RowBox[{
    RowBox[{"operatorsLNC", "=",
     RowBox[{"{", "\[IndentingNewLine]",
      RowBox[{
       RowBox[{"\"\<VLL\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]L \
\!\(\*SuperscriptBox[\(\[Gamma]\), \(\[Mu]\)]\) \
\[Mu]\[InvisibleApplication]L)(\!\(\*OverscriptBox[\(\[Nu]\), \
\(_\)]\)\[InvisibleApplication]\[Alpha] \
\!\(\*SubscriptBox[\(\[Gamma]\), \(\[Mu]\)]\) \[Nu]\[InvisibleApplication]\
\[Beta])\>\"", "<>", "\"\<  [Vector LL]\>\""}]}], ",",
       "\[IndentingNewLine]",
       RowBox[{"\"\<VLR\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]L \
\!\(\*SuperscriptBox[\(\[Gamma]\), \(\[Mu]\)]\) \
\[Mu]\[InvisibleApplication]L)(\!\(\*OverscriptBox[\(\[Nu]\), \
\(_\)]\)\[InvisibleApplication]\[Alpha] \
\!\(\*SubscriptBox[\(\[Gamma]\), \(\[Mu]\)]\) \
\!\(\*SubscriptBox[\(\[Gamma]\), \(5\)]\) \[Nu]\[InvisibleApplication]\[Beta]\
)\>\"", "<>", "\"\<  [Vector LR]\>\""}]}], ",", "\[IndentingNewLine]",
       RowBox[{"\"\<VRL\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]R \
\!\(\*SuperscriptBox[\(\[Gamma]\), \(\[Mu]\)]\) \
\[Mu]\[InvisibleApplication]R)(\!\(\*OverscriptBox[\(\[Nu]\), \
\(_\)]\)\[InvisibleApplication]\[Alpha] \
\!\(\*SubscriptBox[\(\[Gamma]\), \(\[Mu]\)]\) \[Nu]\[InvisibleApplication]\
\[Beta])\>\"", "<>", "\"\<  [Vector RL]\>\""}]}], ",",
       "\[IndentingNewLine]",
       RowBox[{"\"\<VRR\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]R \
\!\(\*SuperscriptBox[\(\[Gamma]\), \(\[Mu]\)]\) \
\[Mu]\[InvisibleApplication]R)(\!\(\*OverscriptBox[\(\[Nu]\), \
\(_\)]\)\[InvisibleApplication]\[Alpha] \
\!\(\*SubscriptBox[\(\[Gamma]\), \(\[Mu]\)]\) \
\!\(\*SubscriptBox[\(\[Gamma]\), \(5\)]\) \[Nu]\[InvisibleApplication]\[Beta]\
)\>\"", "<>", "\"\<  [Vector RR]\>\""}]}], ",", "\[IndentingNewLine]",
       RowBox[{"\"\<SRL\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]R \
\[Mu]\[InvisibleApplication]L)(\!\(\*OverscriptBox[\(\[Nu]\), \
\(_\)]\)\[InvisibleApplication]\[Alpha] \[Nu]\[InvisibleApplication]\[Beta])\>\
\"", "<>", "\"\<  [Scalar RL]\>\""}]}], ",", "\[IndentingNewLine]",
       RowBox[{"\"\<SRR\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]R \
\[Mu]\[InvisibleApplication]L)(\!\(\*OverscriptBox[\(\[Nu]\), \
\(_\)]\)\[InvisibleApplication]\[Alpha] \!\(\*SubscriptBox[\(\[Gamma]\), \
\(5\)]\) \[Nu]\[InvisibleApplication]\[Beta])\>\"", "<>",
         "\"\<  [Scalar RR]\>\""}]}], ",", "\[IndentingNewLine]",
       RowBox[{"\"\<SLL\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]L \
\[Mu]\[InvisibleApplication]R)(\!\(\*OverscriptBox[\(\[Nu]\), \
\(_\)]\)\[InvisibleApplication]\[Alpha] \[Nu]\[InvisibleApplication]\[Beta])\>\
\"", "<>", "\"\<  [Scalar LL]\>\""}]}], ",", "\[IndentingNewLine]",
       RowBox[{"\"\<SLR\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]L \
\[Mu]\[InvisibleApplication]R)(\!\(\*OverscriptBox[\(\[Nu]\), \
\(_\)]\)\[InvisibleApplication]\[Alpha] \!\(\*SubscriptBox[\(\[Gamma]\), \
\(5\)]\) \[Nu]\[InvisibleApplication]\[Beta])\>\"", "<>",
         "\"\<  [Scalar LR]\>\""}]}], ",", "\[IndentingNewLine]",
       RowBox[{"\"\<TRL\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]R \
\!\(\*SuperscriptBox[\(\[Sigma]\), \(\[Mu]\[Nu]\)]\) \
\[Mu]\[InvisibleApplication]L)(\!\(\*OverscriptBox[\(\[Nu]\), \
\(_\)]\)\[InvisibleApplication]\[Alpha] \
\!\(\*SubscriptBox[\(\[Sigma]\), \(\[Mu]\[Nu]\)]\) \[Nu]\[InvisibleApplication]\
\[Beta])\>\"", "<>", "\"\<  [Tensor RL]\>\""}]}], ",",
       "\[IndentingNewLine]",
       RowBox[{"\"\<TLR\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]L \
\!\(\*SuperscriptBox[\(\[Sigma]\), \(\[Mu]\[Nu]\)]\) \
\[Mu]\[InvisibleApplication]R)(\!\(\*OverscriptBox[\(\[Nu]\), \
\(_\)]\)\[InvisibleApplication]\[Alpha] \
\!\(\*SubscriptBox[\(\[Sigma]\), \(\[Mu]\[Nu]\)]\) \[Nu]\[InvisibleApplication]\
\[Beta])\>\"", "<>", "\"\<  [Tensor LR]\>\""}]}]}], "\[IndentingNewLine]",
      "}"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{
     "\"\<\\n===== LEPTON-NUMBER CONSERVING OPERATORS (Delta L = 0) \
=====\\n\>\""}], "]"}], ";"}], "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{"\"\<Process: \[Mu]- \[Rule] e- + \[Nu]\[Alpha] + \
\!\(\*OverscriptBox[\(\[Nu]\), \(_\)]\)\[Beta]\\n\>\""}], "]"}], ";"}],
   "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Do", "[", "\[IndentingNewLine]",
     RowBox[{
      RowBox[{"Print", "[",
       RowBox[{
        RowBox[{"op", "[",
         RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<: \>\"", ",",
        RowBox[{"op", "[",
         RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ",",
      "\[IndentingNewLine]",
      RowBox[{"{",
       RowBox[{"op", ",", "operatorsLNC"}], "}"}]}], "\[IndentingNewLine]",
     "]"}], ";"}], "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{"\"\<\\nTotal LNC operator types: \>\"", ",",
      RowBox[{"Length", "[", "operatorsLNC", "]"}]}], "]"}],
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9, 3.9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{
   "Define", " ", "Lepton", " ", "Number", " ", "Violating", " ",
    "Operators"}], " ", "*)"}], "\[IndentingNewLine]",
  RowBox[{
   RowBox[{
    RowBox[{"operatorsLNV", "=",
     RowBox[{"{", "\[IndentingNewLine]",
      RowBox[{
       RowBox[{"\"\<VLL_LNV\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]L \
\!\(\*SuperscriptBox[\(\[Gamma]\), \(\[Mu]\)]\) \
\[Mu]\[InvisibleApplication]L)(\!\(\*SuperscriptBox[OverscriptBox[\(\[Nu]\), \
\(_\)], \(c\)]\)\[InvisibleApplication]\[Alpha] \
\!\(\*SubscriptBox[\(\[Gamma]\), \(\[Mu]\)]\) \
\!\(\*OverscriptBox[\(\[Nu]\), \(_\)]\)\[InvisibleApplication]\[Beta])\>\"",
         "<>", "\"\<  [Vector LL, LNV]\>\""}]}], ",", "\[IndentingNewLine]",
       RowBox[{"\"\<VLR_LNV\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]L \
\!\(\*SuperscriptBox[\(\[Gamma]\), \(\[Mu]\)]\) \
\[Mu]\[InvisibleApplication]L)(\!\(\*SuperscriptBox[OverscriptBox[\(\[Nu]\), \
\(_\)], \(c\)]\)\[InvisibleApplication]\[Alpha] \
\!\(\*SubscriptBox[\(\[Gamma]\), \(\[Mu]\)]\) \
\!\(\*SubscriptBox[\(\[Gamma]\), \(5\)]\) \
\!\(\*OverscriptBox[\(\[Nu]\), \(_\)]\)\[InvisibleApplication]\[Beta])\>\"",
         "<>", "\"\<  [Vector LR, LNV]\>\""}]}], ",", "\[IndentingNewLine]",
       RowBox[{"\"\<SRL_LNV\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]R \
\[Mu]\[InvisibleApplication]L)(\!\(\*SuperscriptBox[OverscriptBox[\(\[Nu]\), \
\(_\)], \(c\)]\)\[InvisibleApplication]\[Alpha] \
\!\(\*OverscriptBox[\(\[Nu]\), \(_\)]\)\[InvisibleApplication]\[Beta])\>\"",
         "<>", "\"\<  [Scalar RL, LNV]\>\""}]}], ",", "\[IndentingNewLine]",
       RowBox[{"\"\<SRR_LNV\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]R \
\[Mu]\[InvisibleApplication]L)(\!\(\*SuperscriptBox[OverscriptBox[\(\[Nu]\), \
\(_\)], \(c\)]\)\[InvisibleApplication]\[Alpha] \
\!\(\*SubscriptBox[\(\[Gamma]\), \(5\)]\) \
\!\(\*OverscriptBox[\(\[Nu]\), \(_\)]\)\[InvisibleApplication]\[Beta])\>\"",
         "<>", "\"\<  [Scalar RR, LNV]\>\""}]}], ",", "\[IndentingNewLine]",
       RowBox[{"\"\<TRL_LNV\>\"", "->",
        RowBox[{
        "\"\<(\!\(\*OverscriptBox[\(e\), \(_\)]\)\[InvisibleApplication]R \
\!\(\*SuperscriptBox[\(\[Sigma]\), \(\[Mu]\[Nu]\)]\) \
\[Mu]\[InvisibleApplication]L)(\!\(\*SuperscriptBox[OverscriptBox[\(\[Nu]\), \
\(_\)], \(c\)]\)\[InvisibleApplication]\[Alpha] \
\!\(\*SubscriptBox[\(\[Sigma]\), \(\[Mu]\[Nu]\)]\) \
\!\(\*OverscriptBox[\(\[Nu]\), \(_\)]\)\[InvisibleApplication]\[Beta])\>\"",
         "<>", "\"\<  [Tensor RL, LNV]\>\""}]}]}], "\[IndentingNewLine]",
      "}"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{
     "\"\<\\n===== LEPTON-NUMBER VIOLATING OPERATORS (Delta L = 2) \
=====\\n\>\""}], "]"}], ";"}], "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{"\"\<Process: \[Mu]- \[Rule] e- + \
\!\(\*OverscriptBox[\(\[Nu]\), \(_\)]\)\[Alpha] + \
\!\(\*OverscriptBox[\(\[Nu]\), \(_\)]\)\[Beta] (two antineutrinos)\\n\>\""}],
      "]"}], ";"}], "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Do", "[", "\[IndentingNewLine]",
     RowBox[{
      RowBox[{"Print", "[",
       RowBox[{
        RowBox[{"op", "[",
         RowBox[{"[", "1", "]"}], "]"}], ",", "\"\<: \>\"", ",",
        RowBox[{"op", "[",
         RowBox[{"[", "2", "]"}], "]"}]}], "]"}], ",",
      "\[IndentingNewLine]",
      RowBox[{"{",
       RowBox[{"op", ",", "operatorsLNV"}], "}"}]}], "\[IndentingNewLine]",
     "]"}], ";"}], "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{"\"\<\\nTotal LNV operator types: \>\"", ",",
      RowBox[{"Length", "[", "operatorsLNV", "]"}]}], "]"}],
    ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9, 3.9}}]
}, Open  ]],

Cell[CellGroupData[{

Cell["3. Flavor Enumeration", "Section",
 CellChangeTimes->{{3.9, 3.9}}],

Cell["\<\
For each operator structure, we enumerate all possible neutrino flavor \
combinations (alpha, beta). Since alpha and beta can independently be e, mu, \
or tau, we have 9 combinations per operator structure.\
\>", "Text",
 CellChangeTimes->{{3.9, 3.9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ",
   RowBox[{
   "Generate", " ", "all", " ", "flavor", " ", "combinations", " ", "for",
    " ", "a", " ", "given", " ", "operator", " ", "type"}], " ", "*)"}],
  "\[IndentingNewLine]",
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"GenerateFlavorOperators", "[",
      RowBox[{"opType_", ",", "lnc_"}], "]"}], ":=",
     RowBox[{"Module", "[",
      RowBox[{
       RowBox[{"{",
        RowBox[{"operators", "=",
         RowBox[{"{", "}"}]}], "}"}], ",", "\[IndentingNewLine]",
       RowBox[{
        RowBox[{"Do", "[", "\[IndentingNewLine]",
         RowBox[{
          RowBox[{
           RowBox[{"process", "=",
            RowBox[{"If", "[",
             RowBox[{"lnc", ",", "\[IndentingNewLine]",
              RowBox[{
              "\"\<\[Mu]- \[Rule] e- + \>\"", "<>",
               RowBox[{"neutrinos", "[",
                RowBox[{"[", "\[Alpha]", "]"}], "]"}], "<>", "\"\< + \>\"", "<>",
                RowBox[{"antiNeutrinos", "[",
                RowBox[{"[", "\[Beta]", "]"}], "]"}]}], ",",
              "\[IndentingNewLine]",
              RowBox[{
              "\"\<\[Mu]- \[Rule] e- + \>\"", "<>",
               RowBox[{"antiNeutrinos", "[",
                RowBox[{"[", "\[Alpha]", "]"}], "]"}], "<>", "\"\< + \>\"", "<>",
                RowBox[{"antiNeutrinos", "[",
                RowBox[{"[", "\[Beta]", "]"}], "]"}], "<>",
               "\"\< (LNV)\>\""}]}], "\[IndentingNewLine]", "]"}]}], ";",
           "\[IndentingNewLine]",
           RowBox[{"AppendTo", "[",
            RowBox[{"operators", ",",
             RowBox[{"{",
              RowBox[{"opType", ",", "\[Alpha]", ",", "\[Beta]", ",",
               RowBox[{"neutrinos", "[",
                RowBox[{"[", "\[Alpha]", "]"}], "]"}], ",",
               RowBox[{"neutrinos", "[",
                RowBox[{"[", "\[Beta]", "]"}], "]"}], ",", "process"}],
              "}"}]}], "]"}], ";"}], ",", "\[IndentingNewLine]",
          RowBox[{"{",
           RowBox[{"\[Alpha]", ",", "1", ",", "3"}], "}"}], ",",
          RowBox[{"{",
           RowBox[{"\[Beta]", ",", "1", ",", "3"}], "}"}]}],
         "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]",
        "operators"}]}], "\[IndentingNewLine]", "]"}]}], ";"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]",
   RowBox[{"(*", " ",
    RowBox[{
    "Generate", " ", "all", " ", "operators", " ", "with", " ", "flavor",
     " ", "indices"}], " ", "*)"}], "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"allOperatorsLNC", "=",
     RowBox[{"Flatten", "[",
      RowBox[{
       RowBox[{"Table", "[",
        RowBox[{
         RowBox[{"GenerateFlavorOperators", "[",
          RowBox[{
           RowBox[{"operatorsLNC", "[",
            RowBox[{"[",
             RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", "True"}], "]"}],
         ",",
         RowBox[{"{",
          RowBox[{"i", ",",
           RowBox[{"Length", "[", "operatorsLNC", "]"}]}], "}"}]}], "]"}],
       ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]",
   "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"allOperatorsLNV", "=",
     RowBox[{"Flatten", "[",
      RowBox[{
       RowBox[{"Table", "[",
        RowBox[{
         RowBox[{"GenerateFlavorOperators", "[",
          RowBox[{
           RowBox[{"operatorsLNV", "[",
            RowBox[{"[",
             RowBox[{"i", ",", "1"}], "]"}], "]"}], ",", "False"}], "]"}],
         ",",
         RowBox[{"{",
          RowBox[{"i", ",",
           RowBox[{"Length", "[", "operatorsLNV", "]"}]}], "}"}]}], "]"}],
       ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]",
   "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"allOperators", "=",
     RowBox[{"Join", "[",
      RowBox[{"allOperatorsLNC", ",", "allOperatorsLNV"}], "]"}]}], ";"}],
   "\[IndentingNewLine]", "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{"\"\<\\n===== FLAVOR ENUMERATION COMPLETE =====\\n\>\""}], "]"}],
     ";"}], "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{"\"\<Total LNC operators: \>\"", ",",
      RowBox[{"Length", "[", "allOperatorsLNC", "]"}], ",",
      "\"\< = \>\"", ",",
      RowBox[{"Length", "[", "operatorsLNC", "]"}], ",",
      "\"\< types \[Times] 9 flavors\>\""}], "]"}], ";"}],
   "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{"\"\<Total LNV operators: \>\"", ",",
      RowBox[{"Length", "[", "allOperatorsLNV", "]"}], ",", "\"\< = \>\"",
      ",",
      RowBox[{"Length", "[", "operatorsLNV", "]"}], ",",
      "\"\< types \[Times] 9 flavors\>\""}], "]"}], ";"}],
   "\[IndentingNewLine]",
   RowBox[{
    RowBox[{"Print", "[",
     RowBox[{"\"\<TOTAL OPERATORS: \>\"", ",",
